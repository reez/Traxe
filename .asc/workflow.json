          "run": "set -euo pipefail; PROFILE=${steps.resolve_auth_profile.ASC_PROFILE}; SHOULD_SKIP=${steps.detect_today_commits.SHOULD_SKIP}; SKIP_REASON=${steps.detect_today_commits.SKIP_REASON}; RESOLVED_APP_ID=${steps.resolve_app.APP_ID}; IPA_PATH=${steps.export_ipa.IPA_PATH}; VERSION=${steps.resolve_version.VERSION}; BUILD_NUMBER=${steps.export_ipa.BUILD_NUMBER}; GROUP_ID=${steps.ensure_testflight_group.GROUP_ID}; TEST_NOTES_PATH=${steps.resolve_test_notes.TEST_NOTES_PATH}; if [ \"$SHOULD_SKIP\" = \"1\" ]; then jq -n --arg status \"skipped\" --arg skip_reason \"$SKIP_REASON\" --arg version \"$VERSION\" --arg build_number \"\" --arg ipa_path \"\" '{status:$status, skip_reason:$skip_reason, version:$version, build_number:$build_number, ipa_path:$ipa_path, result_json:\"\"}'; exit 0; fi; HELPER=(./.asc/bin/asc-upload-with-retry.sh --app \"$RESOLVED_APP_ID\" --ipa \"$IPA_PATH\" --version \"$VERSION\" --build-number \"$BUILD_NUMBER\" --wait-for-processing \"$WAIT_FOR_PROCESSING\"); if [ -n \"$PROFILE\" ]; then HELPER+=(--profile \"$PROFILE\"); fi; if [ -n \"$TESTFLIGHT_GROUP\" ]; then HELPER+=(--mode publish --group \"$GROUP_ID\" --notify-testers \"$NOTIFY_TESTERS\"); STATUS=\"published\"; else HELPER+=(--mode upload); STATUS=\"uploaded\"; fi; if [ -n \"$TEST_NOTES_PATH\" ] && [ -f \"$TEST_NOTES_PATH\" ]; then HELPER+=(--test-notes-path \"$TEST_NOTES_PATH\" --locale \"$LOCALE\"); fi; RESULT_JSON=\"$(\"${HELPER[@]}\")\"; jq -n --arg status \"$STATUS\" --arg skip_reason \"\" --arg version \"$VERSION\" --arg build_number \"$BUILD_NUMBER\" --arg ipa_path \"$IPA_PATH\" --arg result_json \"$RESULT_JSON\" '{status:$status, skip_reason:$skip_reason, version:$version, build_number:$build_number, ipa_path:$ipa_path, result_json:$result_json}'",
          "outputs": {
            "STATUS": "$.status",
            "SKIP_REASON": "$.skip_reason",
            "VERSION": "$.version",
            "BUILD_NUMBER": "$.build_number",
            "IPA_PATH": "$.ipa_path",
            "RESULT_JSON": "$.result_json"
          }
        }
      ]
    }
  }
}
